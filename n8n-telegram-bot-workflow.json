      "id": "get-next",
      "name": "Получить следующее занятие",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [740, 920]
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst l = data.lesson;\n\nif (!l) {\n  return [{ json: { text: '⏰ *Следующее занятие*\\n\\nНет запланированных занятий.' } }];\n}\n\nconst formatTime = (min) => {\n  if (min < 60) return `${min} мин`;\n  const h = Math.floor(min / 60);\n  const m = min % 60;\n  return m > 0 ? `${h} ч ${m} мин` : `${h} ч`;\n};\n\nlet text = `⏰ *Следующее занятие*\\n\\n`;\ntext += `👤 *${l.student}*\\n`;\ntext += `📚 ${l.subject}\\n`;\ntext += `📖 ${l.topic}\\n`;\ntext += `📅 ${l.date} в *${l.time}*\\n`;\ntext += `⏱ ${l.duration} мин\\n\\n`;\n\nif (l.minutesUntil <= 60) {\n  text += `🔔 Через *${formatTime(l.minutesUntil)}*!`;\n} else {\n  text += `⏳ Через ${formatTime(l.minutesUntil)}`;\n}\n\nreturn [{ json: { text } }];"
      },
      "id": "format-next",
      "name": "Форматировать следующее",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [960, 920]
    },
