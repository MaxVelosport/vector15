      "id": "get-stats",
      "name": "Получить статистику",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [740, 740]
    },
    {
      "parameters": {
        "jsCode": "const s = $input.first().json;\n\nconst formatMoney = (amount) => {\n  return amount.toLocaleString('ru-RU') + ' ₽';\n};\n\nlet text = `📊 *Статистика*\\n\\n`;\ntext += `👥 Активных учеников: *${s.activeStudents}*\\n\\n`;\ntext += `📅 *Сегодня:*\\n`;\ntext += `   Занятий: *${s.todayLessons}*\\n`;\nif (s.todayPending > 0) text += `   🟡 Ожидает: ${s.todayPending}\\n`;\nif (s.todayCompleted > 0) text += `   ✅ Проведено: ${s.todayCompleted}\\n`;\ntext += `\\n`;\ntext += `📈 *За месяц:*\\n`;\ntext += `   Занятий: *${s.monthLessons}*\\n`;\ntext += `   Доход: *${formatMoney(s.monthIncome)}*\\n`;\ntext += `\\n`;\nif (s.uncheckedHomework > 0) {\n  text += `📝 На проверку: *${s.uncheckedHomework}* работ\\n`;\n} else {\n  text += `📝 Все работы проверены ✅\\n`;\n}\n\nreturn [{ json: { text } }];"
      },
      "id": "format-stats",
      "name": "Форматировать статистику",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [960, 740]
    },
