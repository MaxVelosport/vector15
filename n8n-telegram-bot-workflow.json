      "id": "get-homework",
      "name": "Получить домашку",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [740, 560]
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst homework = data.homework || [];\n\nif (homework.length === 0) {\n  return [{ json: { text: '📝 *Домашка на проверку*\\n\\nВсё проверено! Новых работ нет. 🎉' } }];\n}\n\nlet text = `📝 *Домашка на проверку (${homework.length})*\\n\\n`;\n\nfor (let i = 0; i < homework.length; i++) {\n  const h = homework[i];\n  text += `*${i + 1}. ${h.title}*\\n`;\n  text += `   👤 ${h.student}\\n`;\n  if (h.deadline) {\n    const d = new Date(h.deadline);\n    text += `   📅 Дедлайн: ${d.toLocaleDateString('ru-RU')}\\n`;\n  }\n  text += `\\n`;\n}\n\nreturn [{ json: { text } }];"
      },
      "id": "format-homework",
      "name": "Форматировать домашку",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [960, 560]
