    {
      "parameters": {
        "chatId": "={{$('Telegram Trigger').item.json.message.chat.id}}",
        "text": "👋 Привет! Я бот платформы *Твой Вектор*.\n\nДоступные команды:\n\n📅 /today — расписание на сегодня\n👥 /students — список учеников\n📝 /homework — домашка на проверку\n📊 /stats — статистика\n⏰ /next — следующее занятие\n\n_Для работы бота нужно получить API-токен в настройках профиля на сайте._",
        "additionalFields": {
          "parse_mode": "Markdown"
        }
      },
      "id": "send-start",
      "name": "Приветствие",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [740, 40],
      "credentials": {
        "telegramApi": {
          "id": "TELEGRAM_CREDENTIALS_ID",
          "name": "Telegram Bot"
        }
      }
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{$env.APP_URL}}/api/bot/today",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-Bot-Token",
              "value": "={{$env.BOT_API_TOKEN}}"
            }
          ]
        },
        "options": {}
      },
      "id": "get-today",
      "name": "Получить расписание",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [740, 200]
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst lessons = data.lessons || [];\n\nif (lessons.length === 0) {\n  return [{ json: { text: '📅 *Расписание на сегодня*\\n\\nНа сегодня занятий нет. Отдыхайте! 🎉' } }];\n}\n\nlet text = `📅 *Расписание на ${data.date}*\\n\\n`;\ntext += `Всего занятий: *${lessons.length}*\\n\\n`;\n\nconst statusEmoji = {\n  pending: '🟡',\n  completed: '✅',\n  cancelled: '❌',\n  rescheduled: '🔄'\n};\n\nfor (const l of lessons) {\n  const emoji = statusEmoji[l.status] || '⏳';\n  text += `${emoji} *${l.time}* — ${l.student}\\n`;\n  text += `   📚 ${l.subject} · ${l.topic}\\n`;\n  text += `   ⏱ ${l.duration} мин\\n\\n`;\n}\n\nreturn [{ json: { text } }];"
      },
      "id": "format-today",
      "name": "Форматировать расписание",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [960, 200]
    },
    {
      "parameters": {
        "chatId": "={{$('Telegram Trigger').item.json.message.chat.id}}",
        "text": "={{$json.text}}",
        "additionalFields": {
          "parse_mode": "Markdown"
        }
      },
      "id": "send-today",
      "name": "Отправить расписание",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [1180, 200],
      "credentials": {
        "telegramApi": {
          "id": "TELEGRAM_CREDENTIALS_ID",
          "name": "Telegram Bot"
        }
      }
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{$env.APP_URL}}/api/bot/students",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-Bot-Token",
              "value": "={{$env.BOT_API_TOKEN}}"
            }
