      "id": "get-students",
      "name": "Получить учеников",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [740, 380]
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst students = data.students || [];\n\nif (students.length === 0) {\n  return [{ json: { text: '👥 *Ученики*\\n\\nСписок учеников пуст.' } }];\n}\n\nlet text = `👥 *Ученики (${students.length})*\\n\\n`;\n\nfor (let i = 0; i < students.length; i++) {\n  const s = students[i];\n  text += `*${i + 1}. ${s.name}*\\n`;\n  text += `   📚 ${s.subject}`;\n  if (s.grade) text += ` · ${s.grade}`;\n  text += `\\n`;\n  if (s.goal) text += `   🎯 ${s.goal}\\n`;\n  text += `   ✅ ${s.lessonsCompleted || 0} занятий проведено\\n\\n`;\n}\n\nreturn [{ json: { text } }];"
      },
      "id": "format-students",
      "name": "Форматировать учеников",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [960, 380]
    },
    {
      "parameters": {
        "chatId": "={{$('Telegram Trigger').item.json.message.chat.id}}",
        "text": "={{$json.text}}",
        "additionalFields": {
          "parse_mode": "Markdown"
        }
      },
      "id": "send-students",
      "name": "Отправить учеников",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
