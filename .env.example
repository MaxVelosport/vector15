# =============================================================================
# Шаблон переменных окружения для «Твой Вектор»
# =============================================================================
# НЕ копируйте этот файл в .env! В Replit секреты задаются через
# Tools → Secrets (иконка замка слева). Этот файл нужен только как
# справочник: что задать и где взять каждое значение.
#
# Подробная пошаговая инструкция — в QUICKSTART.md
# =============================================================================


# === ОБЯЗАТЕЛЬНЫЕ (без них сервер не стартует) ===

# Supabase — база данных и авторизация
# Где взять: supabase.com → ваш проект → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJ...
SUPABASE_SERVICE_KEY=eyJhbGciOiJ...

# Секрет для шифрования сессий и iCalendar-токенов (минимум 16 символов)
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=замените-на-длинную-случайную-строку

# OpenAI — для ИИ-ассистента и генерации заданий
# Где взять: platform.openai.com → API keys
OPENAI_API_KEY=sk-proj-...

# SMTP пароли для рассылки писем
# По умолчанию используется smtp.beget.com (настройки в .replit → [userenv.shared])
# Если меняете SMTP-провайдера — задайте также SMTP_HOST/PORT/USER/FROM как переменные
SMTP_PASS=пароль-от-info@вашдомен.ru
SMTP_PASS_SUPPORT=пароль-от-support@вашдомен.ru


# === ПОДКЛЮЧЕНИЕ К СУЩЕСТВУЮЩЕЙ БАЗЕ (без создания демо-данных) ===

# Если ваша Supabase уже содержит реальные данные и таблицы:
# SKIP_DEMO_SEED=true   — НЕ создавать демо-аккаунт, НЕ трогать схему вообще
# SKIP_SCHEMA_INIT=true — пропустить ALTER/CREATE TABLE, но создать demo, если его нет
SKIP_DEMO_SEED=


# === ОПЦИОНАЛЬНЫЕ (соответствующие функции просто отключатся) ===

# Telegram-уведомления
# Где взять: Telegram → @BotFather → /newbot
TELEGRAM_BOT_TOKEN=

# Приём онлайн-оплат через ЮKassa
# Где взять: yookassa.ru → Настройки магазина
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# BigBlueButton — встроенные видео-конференции
# Где взять: на сервере BBB выполнить `bbb-conf --secret`
BBB_SECRET=
# URL BBB-сервера задаётся в .replit → [userenv.shared] → BBB_URL


# === ПЕРЕОПРЕДЕЛЕНИЕ SMTP (по умолчанию из .replit) ===
# Раскомментируйте, если используете НЕ smtp.beget.com
# SMTP_HOST=smtp.beget.com
# SMTP_PORT=465
# SMTP_USER=info@вашдомен.ru
# SMTP_FROM=Твой Вектор <info@вашдомен.ru>
# SMTP_SUPPORT=support@вашдомен.ru
